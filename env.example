# ════════════════════════════════════════════════════════════════════════════
#  BIST Multi-Bot Sistemi — Ortam Değişkenleri Şablonu
#  Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
#  .env ASLA git'e push edilmez! (.gitignore'a eklenmiş)
# ════════════════════════════════════════════════════════════════════════════

# ── 1. TELEGRAM BOT TOKENLERI ─────────────────────────────────────────────
# BotFather'dan /newbot → her bot için ayrı token
TELEGRAM_TOKEN=          # CeoWarrenBot token (ANA BOT)
SCANNER_BOT_TOKEN=       # ScannerAgentBot token
NEWS_BOT_TOKEN=          # NewsScanAgentBot token
TRADEBOOK_BOT_TOKEN=     # TradeBookAgentBot token
PROF_BOT_TOKEN=          # ProfGenBot token
ANALYSIS_BOT_TOKEN=      # AnalysisBot token (henüz oluşturulmadı)

# ── 2. TELEGRAM KANAL & TOPIC ID'LERİ ────────────────────────────────────
# Kanalın süper grup ID'si (eksi işaretli)
CHANNEL_ID=-1003827065867

# Topic (Konu) ID'leri — t.me/c/XXXX/YYY'deki YYY kısmı
TOPIC_CEO=7              # CEO Odası
TOPIC_SCANNER=754        # Tarama Odası
TOPIC_ANALYSIS=13        # Finance Check Odası
TOPIC_NEWS=9             # Haber Odası
TOPIC_TRADEBOOK=229      # İşlem Odası
TOPIC_PROF=17            # ProfGen Odası
TOPIC_DEBUG=15           # Hata Ayıklama / Toplantı Odası

# ── 3. RENDER SERVISI ────────────────────────────────────────────────────
# Deploy sonrası Render'ın size verdiği URL
RENDER_URL=https://bist-multi-bot.onrender.com

# ── 4. VERİTABANI ────────────────────────────────────────────────────────
# Render PostgreSQL → Settings → Connection String (External)
DATABASE_URL=postgresql://user:password@hostname:5432/dbname?sslmode=require

# ── 5. AI API ANAHTARLARI ─────────────────────────────────────────────────
# Google AI Studio (aistudio.google.com) → API Key
GEMINI_KEY=
GEMINI_KEY2=             # Opsiyonel — kota yönetimi için yedek
GEMINI_KEY3=             # Opsiyonel — kota yönetimi için yedek

# Groq (console.groq.com) → API Keys
GROQ_KEY=
GROQ_KEY2=               # Opsiyonel
GROQ_KEY3=               # Opsiyonel

# ── 6. SİSTEM AYARLARI ────────────────────────────────────────────────────
WATCHDOG_CHAT_ID=        # Kendi Telegram chat ID'niz (bot ile /start yapın → ID'niz görünür)
TD_DELAY=1.5             # Yahoo Finance indirme arası bekleme (saniye)
PORT=10000               # Flask port (Render otomatik atar, değiştirmeyin)
